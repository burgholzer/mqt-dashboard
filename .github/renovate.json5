{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  suppressNotifications: ["prEditedNotification"],
  minimumReleaseAge: "7 days",
  extends: [
    "config:recommended",
    ":gitSignOff",
    "helpers:pinGitHubActionDigestsToSemver",
    ":automergeDigest",
    ":automergeStableNonMajor",
    ":combinePatchMinorReleases",
    ":configMigration",
    ":enablePreCommit",
    ":prConcurrentLimitNone",
    ":prHourlyLimitNone",
    "schedule:monthly",
  ],
  enabledManagers: [
    "cargo",
    "github-actions",
    "npm",
    "pep621",
    "pip_requirements",
    "pre-commit",
  ],
  lockFileMaintenance: {
    enabled: true,
    automerge: true,
  },
  labels: ["dependencies"],
  packageRules: [
    {
      matchManagers: ["cargo"],
      addLabels: ["rust"],
      commitMessagePrefix: "⬆️🦀",
    },
    {
      matchManagers: ["github-actions"],
      addLabels: ["github-actions"],
      commitMessagePrefix: "⬆️👨‍💻",
    },
    {
      matchManagers: ["npm"],
      addLabels: ["javascript"],
      commitMessagePrefix: "⬆️📜",
    },
    {
      matchManagers: ["pep621", "pip_requirements"],
      addLabels: ["python"],
      commitMessagePrefix: "⬆️🐍",
    },
    {
      matchManagers: ["pre-commit"],
      addLabels: ["pre-commit"],
      commitMessagePrefix: "⬆️🪝",
      versioning: "pep440",
    },
    {
      matchUpdateTypes: ["lockFileMaintenance"],
      commitMessagePrefix: "⬆️🔒️",
    },
    {
      description: "Group and auto-merge all patch updates",
      groupName: "patch updates",
      matchUpdateTypes: ["patch"],
      matchCurrentVersion: "!/^0\\.0/",
      commitMessagePrefix: "⬆️🩹",
      automerge: true,
    },
    {
      description: "Group and auto-merge minor updates of stable dependencies",
      groupName: "minor stable updates",
      matchUpdateTypes: ["minor"],
      matchCurrentVersion: "!/^0\\./",
      matchPackageNames: [
        "!munich-quantum-toolkit/*",
        "!munich-quantum-software/*",
        "!nanobind",
      ],
      commitMessagePrefix: "⬆️🩹",
      automerge: true,
    },
    {
      description: "Disable minimum release age checks for our own GitHub actions",
      matchManagers: ["github-actions"],
      matchPackageNames: [
        "munich-quantum-toolkit/*",
        "munich-quantum-software/*",
      ],
      minimumReleaseAge: null,
    },
    {
      description: "Disable minimum release age checks for our own Python packages",
      matchDatasources: ["pypi"],
      matchPackageNames: ["mqt*"],
      minimumReleaseAge: null,
    },
  ],
}
